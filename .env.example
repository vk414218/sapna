# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Pro – Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to source control.
#
# NOTE: The app ships with built-in defaults for the "vishal-b6def" Firebase
# project so it works out-of-the-box without a .env file.  Use this file only
# if you want to override individual values or switch to your own project.
#
# ⚠️  SECURITY – Firebase Realtime Database rules:
#   Firebase web API keys are public by design (they are embedded in every
#   deployed JS bundle).  The security model relies on Firebase Security Rules,
#   NOT on keeping the key secret.  Before deploying to production you MUST
#   replace the open development rules with auth-based rules:
#
#   Development (open):
#     { "rules": { ".read": true, ".write": true } }
#
#   Production (restrict to authenticated users):
#     { "rules": { ".read": "auth != null", ".write": "auth != null" } }
#
#   Configure at:
#   https://console.firebase.google.com/project/vishal-b6def/database/rules
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini AI – get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase configuration (project: vishal-b6def)
#
# These values are already embedded in the app as defaults.
# Set them here only if you need to override (e.g. to use a different project).
#
# Realtime Database setup (one-time):
#   1. Go to https://console.firebase.google.com/project/vishal-b6def
#   2. Build → Realtime Database → Create Database
#   3. Choose region (default: us-central1 → URL ends in -default-rtdb.firebaseio.com)
#   4. Set initial security rules (see ⚠️ above)
# ─────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSyBCqQkfoLOXzpPTir2U5j1N7Yz0MtZtkFk
VITE_FIREBASE_AUTH_DOMAIN=vishal-b6def.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://vishal-b6def-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=vishal-b6def
VITE_FIREBASE_STORAGE_BUCKET=vishal-b6def.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=684833400978
VITE_FIREBASE_APP_ID=1:684833400978:web:7d5a9b7e5baf5b281d9e4b
VITE_FIREBASE_MEASUREMENT_ID=G-KE7659QK44
