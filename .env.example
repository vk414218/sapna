# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Pro – Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini AI – get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Realtime Database (optional but REQUIRED for cross-device user sync)
#
# Without these values the app works on a single device using localStorage.
# With these values every registered user is visible on ALL devices.
#
# How to set up Firebase (free):
#   1. Go to https://console.firebase.google.com/
#   2. Create a new project (or use an existing one)
#   3. Click "Add app" → Web
#   4. Copy the firebaseConfig values below
#   5. In Firebase console → Build → Realtime Database → Create Database
#   6. Set security rules to allow read/write (for development):
#
#      {
#        "rules": {
#          ".read": true,
#          ".write": true
#        }
#      }
#
#   For production use proper authentication rules.
# ─────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
